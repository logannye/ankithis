# AWS Bedrock credentials (required for Kimi K2.5 card generation)
ANKITHIS_AWS_ACCESS_KEY_ID=AKIA...
ANKITHIS_AWS_SECRET_ACCESS_KEY=...
ANKITHIS_AWS_REGION=us-west-2

# JWT secret (change in production!)
ANKITHIS_JWT_SECRET=change-me-in-production

# These are set automatically in Docker Compose,
# but can be overridden for local development:
# ANKITHIS_DATABASE_URL=postgresql+asyncpg://ankithis:ankithis@localhost:5432/ankithis
# ANKITHIS_REDIS_URL=redis://localhost:6379/0

# S3 storage (optional — defaults to local filesystem)
# ANKITHIS_STORAGE_BACKEND=s3
# ANKITHIS_S3_BUCKET=ankithis
# ANKITHIS_S3_ENDPOINT=https://s3.amazonaws.com
# ANKITHIS_S3_ACCESS_KEY=
# ANKITHIS_S3_SECRET_KEY=
